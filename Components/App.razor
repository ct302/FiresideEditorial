                        "secondary-fixed": "#ffdad6",
                        "primary": "#002f19",
                        "on-primary": "#ffffff",
                        "primary-fixed-dim": "#97d4ad",
                        "surface-bright": "#fff8ef",
                        "surface-container-low": "#fbf3e4",
                        "secondary": "#b51a1b",
                        "primary-fixed": "#b3f0c7",
                        "on-surface": "#1e1b13",
                        "surface-dim": "#e1d9cb",
                        "on-primary-fixed": "#002110",
                        "outline": "#707972",
                        "on-primary-container": "#7ab590",
                        "on-background": "#1e1b13",
                        "surface-container-highest": "#e9e2d3",
                        "error-container": "#ffdad6",
                        "surface-container-high": "#efe7d9",
                        "surface-container": "#f5edde",
