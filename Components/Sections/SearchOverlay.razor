@implements IDisposable
@inject SearchState Search
@inject IContentService Content
@inject IGiftGuideService GuideService
@inject IRecipeService RecipeService
@inject IShopService ShopService
@inject NavigationManager Nav

@if (Search.IsOpen)
{
    <div class="fixed inset-0 z-[60] bg-background/85 backdrop-blur-xl flex flex-col animate-fade-in">
        <div class="max-w-2xl w-full mx-auto px-6 pt-24">
            <div class="flex items-center gap-4 mb-8 bg-background rounded-2xl px-6 py-4 shadow-lg border border-outline-variant/20">
                <span class="material-symbols-outlined text-secondary text-3xl">search</span>
                <input @ref="_inputRef"
                       @bind="_query"
                       @bind:event="oninput"
                       @bind:after="OnSearchAsync"
                       @onkeydown="HandleKeydown"
                       type="text"
                       placeholder="Search articles, recipes, gift guides..."
                       class="flex-grow bg-transparent border-b-2 border-outline-variant/30 focus:border-primary text-on-surface font-headline text-2xl md:text-3xl py-3 outline-none placeholder:text-on-surface-variant/50 transition-colors" />
                <button @onclick="Close" class="material-symbols-outlined text-on-surface-variant hover:text-secondary text-3xl transition-colors">close</button>
            </div>

            @if (_results.Count > 0)
            {
                <div class="space-y-2 overflow-y-auto max-h-[60vh] pr-2 bg-background rounded-2xl p-4 shadow-lg border border-outline-variant/20">
                    @foreach (var result in _results)
                    {
                        <a href="@result.Url" @onclick="Close"
                           class="flex gap-4 p-4 rounded-xl hover:bg-surface-container transition-colors group cursor-pointer">
                            @if (!string.IsNullOrEmpty(result.ImageUrl))
                            {
                                <img src="@result.ImageUrl" alt="" class="w-16 h-16 rounded-lg object-cover shrink-0" loading="lazy" />
                            }
                            else
                            {
                                <div class="w-16 h-16 rounded-lg bg-surface-container flex items-center justify-center shrink-0">
                                    <span class="material-symbols-outlined text-on-surface-variant/30">@result.Icon</span>
                                </div>
                            }
                            <div class="min-w-0">
                                <div class="flex items-center gap-2">
                                    <span class="text-[10px] font-label uppercase tracking-widest text-white bg-primary/80 px-1.5 py-0.5 rounded">@result.Type</span>
                                    <span class="text-xs font-label uppercase tracking-widest text-secondary">@result.Category</span>
                                </div>
                                <h3 class="font-headline text-lg text-on-surface group-hover:text-secondary transition-colors truncate">@result.Title</h3>
                                <p class="text-sm text-on-surface-variant line-clamp-2 mt-1">@result.Snippet</p>
                            </div>
                        </a>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_query) && _query.Length >= 2)
            {
                <div class="text-center py-16 bg-background rounded-2xl shadow-lg border border-outline-variant/20">
                    <span class="material-symbols-outlined text-on-surface-variant/30 text-6xl mb-4">search_off</span>
                    <p class="text-on-surface-variant font-body">Nothing found for "<span class="text-secondary font-semibold">@_query</span>"</p>
                </div>
            }
            else
            {
                <div class="text-center py-16 bg-background rounded-2xl shadow-lg border border-outline-variant/20">
                    <p class="text-on-surface-variant/50 font-body text-sm tracking-wide">Search articles, recipes, gift guides, and the shop...</p>
                </div>
            }
        </div>
    </div>
}

@code {
    private string _query = string.Empty;
    private List<UniversalSearchResult> _results = [];
    private ElementReference _inputRef;
    private CancellationTokenSource? _debounce;

    protected override void OnInitialized()
    {
        Search.OnChange += OnSearchStateChanged;
    }

    private async void OnSearchStateChanged()
    {
        await InvokeAsync(StateHasChanged);
        if (Search.IsOpen)
        {
            await Task.Delay(100);
            try { await _inputRef.FocusAsync(); } catch { }
        }
    }

    private async Task OnSearchAsync()
    {
        _debounce?.Cancel();
        _debounce = new CancellationTokenSource();
        var token = _debounce.Token;

        try
        {
            await Task.Delay(250, token);
            if (!token.IsCancellationRequested && !string.IsNullOrWhiteSpace(_query) && _query.Length >= 2)
            {
                var results = new List<UniversalSearchResult>();
                var terms = _query.ToLowerInvariant().Split(' ', StringSplitOptions.RemoveEmptyEntries);

                // Search journal articles
                var articles = await Content.SearchAsync(_query);
                results.AddRange(articles.Select(a => new UniversalSearchResult
                {
                    Title = a.Title, Category = a.Category, Snippet = a.Snippet,
                    ImageUrl = a.ImageUrl, Url = $"/journal/{a.Slug}", Type = "Journal", Icon = "article"
                }));

                // Search gift guides
                var guides = await GuideService.GetAllGuidesAsync();
                results.AddRange(guides
                    .Where(g => terms.All(t =>
                        g.Title.Contains(t, StringComparison.OrdinalIgnoreCase) ||
                        g.Description.Contains(t, StringComparison.OrdinalIgnoreCase) ||
                        g.Category.Contains(t, StringComparison.OrdinalIgnoreCase) ||
                        g.Products.Any(p => p.Name.Contains(t, StringComparison.OrdinalIgnoreCase))))
                    .Select(g => new UniversalSearchResult
                    {
                        Title = g.Title, Category = g.Category, Snippet = g.Description,
                        ImageUrl = g.ImageUrl, Url = $"/gift-guides/{g.Slug}", Type = "Gift Guide", Icon = "redeem"
                    }));

                // Search recipes
                var recipes = await RecipeService.GetAllRecipesAsync();
                results.AddRange(recipes
                    .Where(r => terms.All(t =>
                        r.Title.Contains(t, StringComparison.OrdinalIgnoreCase) ||
                        r.Description.Contains(t, StringComparison.OrdinalIgnoreCase) ||
                        r.Category.Contains(t, StringComparison.OrdinalIgnoreCase) ||
                        r.Ingredients.Any(i => i.Name.Contains(t, StringComparison.OrdinalIgnoreCase))))
                    .Select(r => new UniversalSearchResult
                    {
                        Title = r.Title, Category = r.Category, Snippet = r.Description,
                        ImageUrl = r.ImageUrl, Url = $"/recipes/{r.Slug}", Type = "Recipe", Icon = "restaurant"
                    }));

                // Search shop products
                var products = await ShopService.GetAllProductsAsync();
                results.AddRange(products
                    .Where(p => terms.All(t =>
                        p.Title.Contains(t, StringComparison.OrdinalIgnoreCase) ||
                        p.Description.Contains(t, StringComparison.OrdinalIgnoreCase) ||
                        p.Category.Contains(t, StringComparison.OrdinalIgnoreCase)))
                    .Select(p => new UniversalSearchResult
                    {
                        Title = p.Title, Category = p.Category, Snippet = p.Description,
                        ImageUrl = p.ImageUrl, Url = "/shop", Type = "Shop", Icon = "storefront"
                    }));

                _results = results;
            }
            else
            {
                _results = [];
            }
        }
        catch (TaskCanceledException) { }
    }

    private void HandleKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") Close();
    }

    private void Close()
    {
        _query = string.Empty;
        _results = [];
        Search.Close();
    }

    public void Dispose()
    {
        Search.OnChange -= OnSearchStateChanged;
        _debounce?.Dispose();
    }

    private class UniversalSearchResult
    {
        public string Title { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
        public string Snippet { get; set; } = string.Empty;
        public string ImageUrl { get; set; } = string.Empty;
        public string Url { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public string Icon { get; set; } = "article";
    }
}
