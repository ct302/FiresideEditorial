@using FiresideEditorial.Models

<div class="my-10 overflow-x-auto">
    <div class="flex items-center gap-2 mb-4">
        <span class="material-symbols-outlined text-secondary text-xl">compare_arrows</span>
        <span class="font-label text-xs uppercase tracking-widest text-secondary font-semibold">@Label</span>
    </div>

    <table class="w-full border-collapse bg-background rounded-xl overflow-hidden border border-outline-variant/30">
        <!-- Header Row -->
        <thead>
            <tr class="bg-primary/5">
                <th class="text-left p-4 font-label text-xs uppercase tracking-widest text-on-surface-variant border-b border-outline-variant/20">Product</th>
                @foreach (var product in Products)
                {
                    <th class="p-4 text-center border-b border-outline-variant/20 min-w-[180px]">
                        <div class="space-y-2">
                            @if (product.IsEditorsPick)
                            {
                                <span class="inline-flex items-center gap-1 bg-primary text-white text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full">
                                    <span class="material-symbols-outlined text-[10px]">workspace_premium</span> Pick
                                </span>
                            }
                            <h4 class="font-headline text-sm text-primary leading-snug">@product.Name</h4>
                            <div class="flex items-center justify-center gap-0.5">
                                @for (int s = 0; s < 5; s++)
                                {
                                    var starFill = s < (int)product.Rating ? "text-amber-500" : "text-outline-variant/30";
                                    <span class="material-symbols-outlined text-xs @starFill" style="font-variation-settings: 'FILL' 1;">star</span>
                                }
                            </div>
                        </div>
                    </th>
                }
            </tr>
        </thead>
        <tbody>
            <!-- Price Row -->
            <tr class="border-b border-outline-variant/10">
                <td class="p-4 font-label text-xs uppercase tracking-widest text-on-surface-variant">Price</td>
                @foreach (var product in Products)
                {
                    <td class="p-4 text-center">
                        <span class="font-bold text-primary text-lg">$@product.Price.ToString("F2")</span>
                        @if (product.OriginalPrice.HasValue && product.OriginalPrice > product.Price)
                        {
                            <span class="block text-on-surface-variant/50 text-xs line-through">$@product.OriginalPrice.Value.ToString("F2")</span>
                        }
                    </td>
                }
            </tr>

            <!-- Feature Rows -->
            @foreach (var feature in AllFeatures)
            {
                <tr class="border-b border-outline-variant/10 last:border-b-0">
                    <td class="p-4 text-sm text-on-surface">@feature</td>
                    @foreach (var product in Products)
                    {
                        var hasFeature = product.Features.Contains(feature);
                        <td class="p-4 text-center">
                            @if (hasFeature)
                            {
                                <span class="material-symbols-outlined text-green-600 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                            }
                            else
                            {
                                <span class="material-symbols-outlined text-outline-variant/30 text-lg">cancel</span>
                            }
                        </td>
                    }
                </tr>
            }

            <!-- CTA Row -->
            <tr class="bg-primary/5">
                <td class="p-4"></td>
                @foreach (var product in Products)
                {
                    <td class="p-4 text-center">
                        <a href="@product.AffiliateUrl"
                           target="_blank"
                           rel="noopener noreferrer sponsored"
                           class="inline-block bg-secondary text-white px-5 py-2.5 rounded-lg font-bold uppercase tracking-widest text-[10px] hover:brightness-110 transition-all shadow-sm shadow-secondary/20">
                            View Deal
                        </a>
                    </td>
                }
            </tr>
        </tbody>
    </table>
    <p class="text-on-surface-variant/60 text-[10px] mt-3 italic">As an Amazon Associate, The Fireside Editorial earns from qualifying purchases.</p>
</div>

@code {
    [Parameter] public string Label { get; set; } = "Compare Products";
    [Parameter] public List<AffiliateProduct> Products { get; set; } = [];

    private List<string> AllFeatures => Products
        .SelectMany(p => p.Features)
        .Distinct()
        .ToList();
}
