@implements IDisposable
@inject NavigationManager Nav
@inject SearchState Search

<nav class="fixed top-0 w-full z-50 px-6 py-4 md:px-12 bg-background/95 backdrop-blur-md shadow-[0_2px_15px_rgba(30,27,19,0.05)]">
    <div class="flex items-center justify-between">
        <div class="flex items-center gap-2 shrink-0">
            <span class="material-symbols-outlined text-2xl" style="color: #05472A;">park</span>
            <a href="/" class="font-headline font-bold text-2xl tracking-tight italic whitespace-nowrap" style="color: #05472A;">The Fireside Editorial</a>
        </div>
        <div class="hidden lg:flex items-center justify-center gap-6 absolute left-1/2 -translate-x-1/2">
            <a class="@NavClass("/") font-label text-sm uppercase tracking-widest hover:text-secondary transition-colors duration-300" href="/">Home</a>
            <a class="@NavClass("/journal") font-label text-sm uppercase tracking-widest hover:text-secondary transition-colors duration-300" href="/journal">Journal</a>
            <a class="@NavClass("/gift-guides") font-label text-sm uppercase tracking-widest hover:text-secondary transition-colors duration-300" href="/gift-guides">Gift Guides</a>
            <a class="@NavClass("/recipes") font-label text-sm uppercase tracking-widest hover:text-secondary transition-colors duration-300" href="/recipes">Recipes</a>
            <a class="@NavClass("/shop") font-label text-sm uppercase tracking-widest hover:text-secondary transition-colors duration-300" href="/shop">Shop</a>
            <a class="@NavClass("/about") font-label text-sm uppercase tracking-widest hover:text-secondary transition-colors duration-300" href="/about">Our Story</a>
        </div>
        <div class="flex items-center gap-4 shrink-0">
            <button @onclick="Search.Open" class="material-symbols-outlined scale-95 active:scale-90 transition-transform hidden lg:block" style="color: #05472A;">search</button>
            <button class="material-symbols-outlined lg:hidden text-2xl active:scale-90 transition-transform" style="color: #05472A;" @onclick="ToggleMobile">
                @(_mobileOpen ? "close" : "menu")
            </button>
        </div>
    </div>
</nav>

@if (_mobileOpen)
{
    <div class="fixed inset-0 z-40 bg-background/98 backdrop-blur-lg flex flex-col items-center justify-center gap-8 lg:hidden animate-fade-in">
        <a class="@MobileNavClass("/") font-headline text-2xl tracking-wide" href="/" @onclick="CloseMobile">Home</a>
        <a class="@MobileNavClass("/journal") font-headline text-2xl tracking-wide hover:text-secondary transition-colors" href="/journal" @onclick="CloseMobile">Journal</a>
        <a class="@MobileNavClass("/gift-guides") font-headline text-2xl tracking-wide hover:text-secondary transition-colors" href="/gift-guides" @onclick="CloseMobile">Gift Guides</a>
        <a class="@MobileNavClass("/recipes") font-headline text-2xl tracking-wide hover:text-secondary transition-colors" href="/recipes" @onclick="CloseMobile">Recipes</a>
        <a class="@MobileNavClass("/shop") font-headline text-2xl tracking-wide hover:text-secondary transition-colors" href="/shop" @onclick="CloseMobile">Shop</a>
        <a class="@MobileNavClass("/about") font-headline text-2xl tracking-wide hover:text-secondary transition-colors" href="/about" @onclick="CloseMobile">Our Story</a>
        <button @onclick="OpenSearchFromMobile" class="font-headline text-2xl tracking-wide text-on-surface hover:text-secondary transition-colors flex items-center gap-3">
            <span class="material-symbols-outlined">search</span> Search
        </button>
        <div class="w-12 h-px bg-secondary/30 rounded-full mt-4"></div>
        <span class="text-on-surface-variant/50 font-label text-xs uppercase tracking-[0.3em]">The Fireside Editorial</span>
    </div>
}

@code {
    private bool _mobileOpen;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _mobileOpen = false;
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleMobile() => _mobileOpen = !_mobileOpen;
    private void CloseMobile() => _mobileOpen = false;
    private void OpenSearchFromMobile()
    {
        _mobileOpen = false;
        Search.Open();
    }

    private string NavClass(string href)
    {
        return IsActive(href)
            ? "text-secondary font-semibold"
            : "text-on-surface";
    }

    private string MobileNavClass(string href)
    {
        return IsActive(href)
            ? "text-secondary font-semibold"
            : "text-on-surface";
    }

    private bool IsActive(string href)
    {
        var currentPath = new Uri(Nav.Uri).AbsolutePath;

        // Hash links are section anchors, never highlight them
        if (href.Contains('#'))
            return false;

        // Exact match for home
        if (href == "/")
            return currentPath == "/";

        // /journal matches /journal and /journal/{slug}
        if (href == "/journal")
            return currentPath.StartsWith("/journal", StringComparison.OrdinalIgnoreCase);

        // /gift-guides matches /gift-guides and /gift-guides/{slug}
        if (href == "/gift-guides")
            return currentPath.StartsWith("/gift-guides", StringComparison.OrdinalIgnoreCase);

        // /recipes matches /recipes and /recipes/{slug}
        if (href == "/recipes")
            return currentPath.StartsWith("/recipes", StringComparison.OrdinalIgnoreCase);

        // Everything else: exact prefix match
        return currentPath.StartsWith(href, StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
