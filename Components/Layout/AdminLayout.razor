@inherits LayoutComponentBase

<div class="flex min-h-screen bg-background">
    <aside class="w-64 bg-primary text-white flex flex-col shrink-0">
        <div class="p-6 border-b border-white/10">
            <a href="/" class="font-headline text-lg italic tracking-tight flex items-center gap-2">
                <span class="material-symbols-outlined text-xl">park</span>
                Fireside Admin
            </a>
        </div>
        <nav class="flex-1 p-4 space-y-1">
            <AdminNavLink Href="/admin" Icon="dashboard" Label="Dashboard" />
            <AdminNavLink Href="/admin/cards" Icon="view_module" Label="Cards" />
            <AdminNavLink Href="/admin/quotes" Icon="format_quote" Label="Quotes" />
            <AdminNavLink Href="/admin/traditions" Icon="diversity_3" Label="Traditions" />
        </nav>
        <div class="p-4 border-t border-white/10">
            <a href="/admin/logout" class="flex items-center gap-2 text-white/60 hover:text-white text-sm transition-colors">
                <span class="material-symbols-outlined text-lg">logout</span>
                Sign Out
            </a>
        </div>
    </aside>
    <main class="flex-1 p-8 overflow-auto">
        @Body
    </main>
</div>
