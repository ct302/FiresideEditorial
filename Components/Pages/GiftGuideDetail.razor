@page "/gift-guides/{Slug}"
@using FiresideEditorial.Models
@using FiresideEditorial.Services
@inject IGiftGuideService GuideService

@if (_guide is null)
{
    <section class="pt-32 pb-24 px-6 text-center">
        <h1 class="font-headline text-4xl text-primary mb-4">Guide Not Found</h1>
        <p class="text-on-surface-variant mb-8">We couldn't find this gift guide.</p>
        <a href="/gift-guides" class="text-secondary font-bold uppercase tracking-widest text-sm">Back to Gift Guides</a>
    </section>
}
else
{
    <PageTitle>@_guide.Title | Gift Guides | The Fireside Editorial</PageTitle>

    <HeadContent>
        <meta name="description" content="@_guide.Description" />
        <meta property="og:title" content="@_guide.Title | The Fireside Editorial Gift Guide" />
        <meta property="og:description" content="@_guide.Description" />
        <meta property="og:type" content="article" />
        <meta property="og:image" content="@_guide.ImageUrl" />
    </HeadContent>

    <!-- Hero -->
    <section class="relative h-[400px] flex items-end overflow-hidden pt-20">
        <div class="absolute inset-0">
            <img src="@_guide.ImageUrl" alt="@_guide.ImageAlt" class="editorial-img w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/40 to-transparent"></div>
        </div>
        <div class="relative z-10 max-w-5xl mx-auto px-6 md:px-12 pb-12 w-full">
            <a href="/gift-guides" class="inline-flex items-center gap-1 text-white/70 hover:text-white text-xs font-label uppercase tracking-widest mb-6 transition-colors">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
                All Gift Guides
            </a>
            <div class="flex items-center gap-3 mb-3">
                <span class="bg-white/20 text-white text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-full">@_guide.Category</span>
                <span class="bg-white/20 text-white text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-full">@_guide.PriceRange</span>
            </div>
            <h1 class="font-headline text-4xl md:text-5xl text-white leading-tight">@_guide.Title</h1>
            <p class="text-white/70 mt-3 max-w-xl">@_guide.Description</p>
        </div>
    </section>

    <!-- Products -->
    <section class="max-w-5xl mx-auto px-6 md:px-12 py-16">
        <!-- Top Picks Block -->
        <TopPicksBlock Label="Our Picks" Title="@_guide.Title" Products="@_guide.Products" />

        <!-- Comparison Table -->
        @if (_guide.Products.Count >= 2)
        {
            <ComparisonTable Label="Quick Comparison" Products="@_guide.Products" />
        }

        <!-- Newsletter CTA -->
        <div class="mt-16 border-t border-outline-variant/30 pt-12 text-center">
            <span class="material-symbols-outlined text-secondary text-3xl mb-3">redeem</span>
            <h3 class="font-headline text-2xl text-primary mb-2">Want More Gift Ideas?</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed max-w-md mx-auto mb-6">Subscribe and we'll send you curated picks, seasonal deals, and new guides before anyone else.</p>
            <a href="/#newsletter" class="bg-secondary text-white px-8 py-4 rounded-lg font-bold uppercase tracking-widest text-sm hover:brightness-110 transition-all shadow-lg shadow-secondary/20 inline-flex items-center gap-2">
                <span class="material-symbols-outlined text-lg">mark_email_read</span>
                Subscribe Free
            </a>
        </div>
    </section>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private GiftGuide? _guide;

    protected override async Task OnParametersSetAsync()
    {
        _guide = await GuideService.GetGuideBySlugAsync(Slug);
    }
}
