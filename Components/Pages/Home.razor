@page "/"
@using FiresideEditorial.Models
@using FiresideEditorial.Services
@inject IContentService ContentService

<PageTitle>The Fireside Editorial | Curating Winter Traditions</PageTitle>

<HeadContent>
    <meta name="description" content="Escape into a world of timeless winter wonder. The Fireside Editorial curates holiday traditions, recipes, and stories told by the hearth." />
    <meta property="og:title" content="The Fireside Editorial | Curating Winter Traditions" />
    <meta property="og:description" content="Holiday traditions, heirloom recipes, and stories worth keeping — curated by the hearth since 2026." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://images.unsplash.com/photo-1543589077-47d81606c1bf?auto=format&fit=crop&q=80&w=1200" />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "WebSite",
        "name": "The Fireside Editorial",
        "description": "Curating the magic of the winter season — holiday traditions, heirloom recipes, and stories told by the hearth.",
        "url": "https://thefiresideeditorial.com",
        "publisher": {
            "@@type": "Organization",
            "name": "The Fireside Editorial",
            "foundingDate": "2026"
        }
    }
    </script>
</HeadContent>

<HeroSection />

<InspirationsGrid Cards="@_cards" />

<QuoteSection Quote="@_quote" />

<AdventCountdown />

<NewsletterSection />

<ShareTraditionForm />

@code {
    private List<EditorialCardModel> _cards = [];
    private QuoteModel _quote = new();

    protected override async Task OnInitializedAsync()
    {
        _cards = await ContentService.GetCardsAsync(9);
        _quote = await ContentService.GetQuoteAsync();
    }
}
